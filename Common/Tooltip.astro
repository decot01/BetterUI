---
export interface Props {
  text: string;
  shortcut?: string;
}

const { text, shortcut } = Astro.props;
---

<div class="tooltip-trigger-wrap" data-tooltip-wrap>
  <slot />
  <div class="tooltip-floating" role="tooltip" aria-hidden="true" data-tooltip-popover>
    <div class="tooltip-entry">
      <span class="tooltip-text">{text}</span>
      <div class="tooltip-shortcuts">
        {shortcut && (
          <span class="shortcut-key-item">{shortcut}</span>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  .tooltip-trigger-wrap {
    position: relative;
    display: inline-block;
  }

  .tooltip-floating {
    position: fixed;
    z-index: 9999;
    pointer-events: none;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.2s var(--easing_ExtremeInOut), visibility 0s linear 0.2s;
  }

  .tooltip-floating.is-visible {
    visibility: visible;
    opacity: 1;
    transition: opacity 0.2s var(--easing_ExtremeInOut);
  }

  .tooltip-entry {
    font-weight: 500;
    display: flex;
    align-items: center;
    padding: 5px 12px;
    background-color: var(--color_00);
    color: var(--color_08);
    font-family: Arial, sans-serif;
    font-size: 16px;
    white-space: nowrap;
    border: 1px solid var(--color_03);
  }

  .tooltip-text {
    margin-right: 12px;
  }

  .tooltip-shortcuts {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color_04);
    font-size: 16px;
  }

  .shortcut-key-item {
  }
</style>

<script>
  (function () {
    const GAP = 8;
    const SHOW_DELAY = 300;

    function findWraps(): NodeListOf<Element> {
      return document.querySelectorAll('[data-tooltip-wrap]');
    }

    function init(wrap: Element) {
      const wrapEl = wrap as HTMLElement;
      if (!wrapEl || wrapEl.dataset.tooltipInit === 'true') return;
      const popover = wrap.querySelector('[data-tooltip-popover]') as HTMLElement | null;
      const trigger = wrap.firstElementChild as HTMLElement | null;
      if (!popover || !trigger) return;
      const popoverEl: HTMLElement = popover;
      const triggerEl: HTMLElement = trigger;

      let showTimer: ReturnType<typeof setTimeout> | null = null;
      let hideTimer: ReturnType<typeof setTimeout> | null = null;

      function getPlacement(triggerRect: DOMRect, popoverW: number, popoverH: number): 'top' | 'bottom' | 'left' | 'right' {
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const spaceTop = triggerRect.top;
        const spaceBottom = vh - triggerRect.bottom;
        const spaceLeft = triggerRect.left;
        const spaceRight = vw - triggerRect.right;
        const needW = popoverW + GAP;
        const needH = popoverH + GAP;

        const canTop = spaceTop >= needH;
        const canBottom = spaceBottom >= needH;
        const canLeft = spaceLeft >= needW;
        const canRight = spaceRight >= needW;

        if (canTop && (spaceTop >= spaceBottom || !canBottom)) return 'top';
        if (canBottom) return 'bottom';
        if (canLeft && (spaceLeft >= spaceRight || !canRight)) return 'left';
        if (canRight) return 'right';
        return spaceTop >= spaceBottom ? 'top' : 'bottom';
      }

      function show() {
        hideTimer && clearTimeout(hideTimer);
        hideTimer = null;
        showTimer = setTimeout(() => {
          showTimer = null;
          if (popoverEl.parentNode !== document.body) {
            document.body.appendChild(popoverEl);
          }
          const triggerRect = triggerEl.getBoundingClientRect();
          popoverEl.style.left = '0';
          popoverEl.style.top = '0';
          popoverEl.style.removeProperty('bottom');
          popoverEl.style.removeProperty('right');
          popoverEl.style.removeProperty('transform');
          popoverEl.classList.remove('is-visible');
          popoverEl.style.visibility = 'hidden';
          popoverEl.style.display = '';
          const popoverRect = popoverEl.getBoundingClientRect();
          const pw = popoverRect.width;
          const ph = popoverRect.height;
          popoverEl.style.visibility = '';
          const placement = getPlacement(triggerRect, pw, ph);

          let left = 0;
          let top = 0;
          switch (placement) {
            case 'top':
              left = triggerRect.left + triggerRect.width / 2 - pw / 2;
              top = triggerRect.top - ph - GAP;
              break;
            case 'bottom':
              left = triggerRect.left + triggerRect.width / 2 - pw / 2;
              top = triggerRect.bottom + GAP;
              break;
            case 'left':
              left = triggerRect.left - pw - GAP;
              top = triggerRect.top + triggerRect.height / 2 - ph / 2;
              break;
            case 'right':
              left = triggerRect.right + GAP;
              top = triggerRect.top + triggerRect.height / 2 - ph / 2;
              break;
          }
          const vw = window.innerWidth;
          const vh = window.innerHeight;
          left = Math.max(GAP, Math.min(vw - pw - GAP, left));
          top = Math.max(GAP, Math.min(vh - ph - GAP, top));

          popoverEl.style.left = `${left}px`;
          popoverEl.style.top = `${top}px`;
          popoverEl.classList.add('is-visible');
        }, SHOW_DELAY);
      }

      function hide() {
        if (showTimer) {
          clearTimeout(showTimer);
          showTimer = null;
        }
        hideTimer = setTimeout(() => {
          hideTimer = null;
          popoverEl.classList.remove('is-visible');
        }, 100);
      }

      wrapEl.addEventListener('mouseenter', show);
      wrapEl.addEventListener('mouseleave', hide);
      wrapEl.dataset.tooltipInit = 'true';
    }

    function tryInit() {
      findWraps().forEach(init);
    }

    function scheduleInits() {
      tryInit();
      setTimeout(tryInit, 100);
      setTimeout(tryInit, 500);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scheduleInits);
    } else {
      scheduleInits();
    }

    let observerScheduled = false;
    const observer = new MutationObserver(() => {
      if (observerScheduled) return;
      observerScheduled = true;
      requestAnimationFrame(() => {
        tryInit();
        observerScheduled = false;
      });
    });
    if (document.body) {
      observer.observe(document.body, { childList: true, subtree: true });
    }
  })();
</script>
