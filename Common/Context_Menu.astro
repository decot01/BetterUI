---
export interface MenuItem {
  type: 'item' | 'separator';
  label?: string;
  shortcut?: string;
  submenu?: MenuItem[];
  disabled?: boolean;
  action?: string;
}

interface Props {
  items: MenuItem[];
}

const { items } = Astro.props;
---

<div class="context-menu">
  {items.map(item => {

    if (item.type === 'separator') {
      return <hr class="separator" />;
    }

    return (
      <div class="menu-item-wrapper" class:list={[item.submenu && item.submenu.length > 0 && 'has-submenu']} data-has-submenu={item.submenu?.length ? 'true' : undefined}>
        <div class="menu-item" data-action={item.action}>
          <span class="label">{item.label}</span>
          {item.shortcut && <span class="shortcut">{item.shortcut}</span>}
          {item.submenu && item.submenu.length > 0 && <span class="submenu-arrow">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11 10L13.1213 12.1213L11 14.2426" stroke="var(--color_06)"/></svg>
            </span>}
        </div>
        
        {item.submenu && item.submenu.length > 0 && (
          <div class="submenu-container">
            <Astro.self items={item.submenu} />
          </div>
        )}
      </div>
    );
  })}
</div>

<script>
  function initializeMenu(menuElement: HTMLElement) {
    if (menuElement.dataset.contextMenuInit === 'true') return;
    menuElement.dataset.contextMenuInit = 'true';

    menuElement.addEventListener('click', (e) => {
      const item = (e.target as HTMLElement).closest('.menu-item') as HTMLElement | null;
      if (!item) return;
      const insideSubmenu = (e.target as HTMLElement).closest('.submenu-container');
      const onParentWithSubmenu = (e.target as HTMLElement).closest('.menu-item-wrapper[data-has-submenu="true"]');
      if (onParentWithSubmenu && !insideSubmenu) return;

      const action = (item as HTMLElement).dataset.action;
      if (!item.hasAttribute('disabled') && action) {
        const event = new CustomEvent('menuaction', {
          bubbles: true,
          composed: true,
          detail: { action }
        });
        item.dispatchEvent(event);
      }
    });
  }

  document.querySelectorAll('.context-menu').forEach((el) => initializeMenu(el as HTMLElement));

  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      mutation.addedNodes.forEach((node) => {
        if (node instanceof HTMLElement) {
          if (node.classList?.contains('context-menu')) initializeMenu(node);
          node.querySelectorAll?.('.context-menu').forEach((n) => initializeMenu(n as HTMLElement));
        }
      });
    });
  });
  observer.observe(document.body, { childList: true, subtree: true });
</script>

<style>
  .context-menu {
    background-color: var(--color_00);
    color: var(--color_10);
    font-size: 14px;
    padding: 6px;
    font-weight: 500;
    width: fit-content;
    border: 1px solid var(--color_03);
    user-select: none;
    z-index: 99;
  }

  .menu-item-wrapper {
    position: relative;
  }

  .submenu-container {
    opacity: 0;
    visibility: hidden;
    position: absolute;
    left: 100%;
    top: -6px;
    padding-left: 1px;
    z-index: 99;
    transition: opacity 0.2s var(--easing_ExtremeInOut), visibility 0s linear 0.2s;
  }

  .menu-item-wrapper.has-submenu:hover > .submenu-container {
    opacity: 1;
    visibility: visible;
    z-index: 99;
  }


  .menu-item {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    background: none;
    border: none;
    color: inherit;
    text-align: left;
    cursor: pointer;
    white-space: nowrap;
    z-index: 99;
  }

  .menu-item:hover {
    background-color: var(--color_01);
    z-index: 99;
  }

  .menu-item[disabled] {
    color: var(--color_04);
    cursor: not-allowed;
    background-color: transparent;
    
  }

  .label {
    flex-grow: 1;
  }

  .shortcut {
    color: var(--color_04);
    margin-left: 24px;
  }

  .submenu-arrow {
    color: var(--color_04);
    margin-left: 8px;
    font-weight: bold;
  }

  .separator {
    border: none;
    height: 1px;
    background-color: var(--color_02);
    margin: 6px 0;
  }
</style>